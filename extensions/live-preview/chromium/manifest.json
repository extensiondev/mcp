{
  "version": "0.0.1",
  "name": "Extension.dev Live Preview",
  "author": "Extension.dev",
  "description": "Lends real browser powers to the extension you are previewing on Extension.dev. Install while building so your popup, content scripts, and APIs run for real.",
  "key": "",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "64": "images/icon.png",
      "128": "images/icon.png"
    },
    "default_title": "Extension.dev Live Preview",
    "default_popup": "action/index.html"
  },
  "externally_connectable": {
    "matches": [
      "https://intelligence.extension.dev/*",
      "https://inspect.extension.dev/*",
      "https://themes.extension.dev/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "permissions": [
    "storage",
    "notifications",
    "contextMenus",
    "downloads",
    "cookies",
    "scripting",
    "management",
    "activeTab",
    "tabs",
    "alarms",
    "offscreen",
    "webNavigation",
    "bookmarks",
    "history",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "sandbox": {
    "pages": [
      "sandbox/page-0.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-forms allow-modals allow-popups; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; child-src data: blob:;"
  }
}