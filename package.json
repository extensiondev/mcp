{
  "name": "@extension.dev/mcp",
  "type": "module",
  "version": "4.3.0",
  "description": "MCP server that lets AI agents (Claude Code, Claude Desktop, Cursor, Copilot, Codex) build, run, inspect, and publish browser extensions. 29 tools for scaffolding, live DOM inspection, log streaming, and store-ready builds across Chrome, Edge, and Firefox. Powered by extension.dev and Extension.js.",
  "mcpName": "io.github.extensiondev/mcp",
  "license": "MIT",
  "author": {
    "name": "Cezar Augusto",
    "email": "boss@cezaraugusto.net",
    "url": "https://cezaraugusto.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/extensiondev/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/extensiondev/mcp/issues"
  },
  "homepage": "https://extension.dev",
  "engines": {
    "node": ">=20.18"
  },
  "packageManager": "pnpm@10.19.0",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    }
  },
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "bin": {
    "extension-mcp": "./bin/extension-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "claude",
    ".claude-plugin",
    "server.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "watch": "rslib build --watch",
    "compile": "rslib build",
    "build": "pnpm run compile",
    "start": "node bin/extension-mcp.js",
    "test": "vitest run",
    "prepublishOnly": "pnpm run test && pnpm run compile"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "agents",
    "claude",
    "claude-code",
    "claude-desktop",
    "cursor",
    "github-copilot",
    "codex",
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "edge-extension",
    "manifest-v3",
    "webextension",
    "cross-browser",
    "developer-tools",
    "extension.dev",
    "extension.js"
  ],
  "dependencies": {
    "@extension.dev/core": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "browser-extension-manifest-fields": "^2.2.9",
    "cross-spawn": "^7.0.6",
    "extension-create": "^4.0.8",
    "extension-develop": "^4.0.8",
    "extension-install": "^4.0.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.19.4",
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "typescript": "6.0.2",
    "vitest": "^4.1.3"
  }
}
